# ==================================================
# Корневой .gitignore для всего проекта SENSEI
# Что git НИКОГДА не загружает в GitHub
# ==================================================

# --- Секретные токены (Telegram, OpenAI и т.д.) ---
.env
CODE/.env
**/.env

# --- Данные пользователя (база, документы, голос, бэкапы) ---
CODE/data/
**/data/

# --- Служебные файлы Python ---
__pycache__/
*.pyc
*.pyo

# --- Резервные копии ---
*.bak
CODE/backups/

# --- Системный мусор ОС ---
Thumbs.db
desktop.ini
.DS_Store

# --- ltm-power ---
ltm/store/*.jsonl
ltm/runtime/*
ltm/reports/*
ltm/snapshots/*
# --- /ltm-power ---

# secrets — не коммитить (added 2026-06-20)
*.key
*.key.pub
*.pem
ai-backups-*.json
*credentials*.json
