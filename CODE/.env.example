# ==================================================
# ШАБЛОН СЕКРЕТНЫХ ТОКЕНОВ (ОБРАЗЕЦ)
# ==================================================
# Это безопасный пример без настоящих ключей.
# Чтобы настроить бота:
#   1. Скопируйте этот файл и назовите копию ".env"
#   2. Впишите свои настоящие токены вместо подсказок ниже
#
# Где взять токены:
#   TELEGRAM_TOKEN — у @BotFather в Telegram (команда /mybots -> API Token)
#   OPENAI_API_KEY — на сайте platform.openai.com -> раздел API keys
# ==================================================

TELEGRAM_TOKEN=your-telegram-bot-token-here
OPENAI_API_KEY=your-openai-api-key-here

# ==================================================
# ЗАЩИТА ПАМЯТИ — КОПИИ В TELEGRAM-КАНАЛ (Этап 1)
# ==================================================
# ID приватного канала, куда бот шлёт копии. Бот должен быть там админом.
# Если оставить пустым — отправка в канал отключена, бот работает как обычно.
BACKUP_CHANNEL_ID=-100XXXXXXXXXX

# Выключатель отправки копий. true (по умолчанию) — включено; false — отключено.
BACKUP_ENABLED=true

# Интервалы (в секундах). Можно не указывать — будут значения по умолчанию.
#   База + текстовый экспорт — каждые 6 часов (21600)
#   Архив кода — раз в неделю (604800)
BACKUP_DB_INTERVAL_SECONDS=21600
BACKUP_CODE_INTERVAL_SECONDS=604800
